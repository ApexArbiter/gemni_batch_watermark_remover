{
  "fallback": {
    "w_frac": 0.16,
    "h_frac": 0.24,
    "margin_frac": 0.06,
    "pad_frac": 0.0
  },
  "rules": [
    {
      "if": { "max_short_side": 680, "max_long_side": 680 },
      "then": { "w_frac": 0.26, "h_frac": 0.26, "margin_frac": 0.04, "pad_frac": 0.0 }
    },
    {
      "if": {
        "width_min": 950,
        "width_max": 1100,
        "height_min": 950,
        "height_max": 1100,
        "aspect_min": 0.95,
        "aspect_max": 1.05
      },
      "then": { "w_frac": 0.2, "h_frac": 0.2, "margin_frac": 0.05, "pad_frac": 0.0 }
    },
    {
      "if": { "width_min": 1260, "width_max": 1310, "height_min": 685, "height_max": 715, "aspect_min": 1.7 },
      "then": { "w_frac": 0.14, "h_frac": 0.24, "margin_frac": 0.07, "pad_frac": 0.0 }
    },
    {
      "if": { "width_min": 1415, "width_max": 1445, "height_min": 773, "height_max": 785 },
      "then": { "w_frac": 0.13, "h_frac": 0.22, "margin_frac": 0.07, "pad_frac": 0.0 }
    },
    {
      "if": { "width_min": 1585, "width_max": 1615, "height_min": 862, "height_max": 882 },
      "then": { "w_frac": 0.12, "h_frac": 0.2, "margin_frac": 0.08, "pad_frac": 0.0 }
    }
  ]
}
